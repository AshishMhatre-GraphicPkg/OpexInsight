<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<style>
  body { font-family: Calibri, Arial, sans-serif; font-size: 14px; color: #1a1a1a; }
  h2 { color: #003366; border-bottom: 2px solid #003366; padding-bottom: 4px; }
  h3 { color: #005099; margin-top: 24px; margin-bottom: 4px; }
  .impact { font-size: 1.05em; }
  .levers { margin-top: 8px; padding-left: 18px; }
  .levers li { margin-bottom: 4px; }
  .streak { color: #c0392b; font-weight: bold; }
  .findings { margin-top: 14px; background: #f9f9f9; border-left: 3px solid #c0392b; padding: 8px 12px; border-radius: 2px; }
  .findings h4 { margin: 0 0 6px; color: #7b0000; font-size: 0.95em; }
  .findings p { margin: 4px 0; }
  .findings-sections { margin: 6px 0 4px; padding-left: 16px; }
  .findings-sections li { margin-bottom: 3px; font-size: 0.93em; }
  .findings-sections li.corroborated { font-weight: bold; color: #7b0000; }
  .findings-note { font-size: 0.85em; color: #666; margin-top: 6px; }
  .footer { margin-top: 32px; font-size: 12px; color: #888; border-top: 1px solid #ddd; padding-top: 8px; }
</style>
</head>
<body>

<h2>{{ subject }}</h2>
<p>Week of <strong>{{ digest.period_start }}</strong></p>

{% for m in digest.machines %}
<h3>{{ m.plant_wc }} — {{ m.department }}</h3>
<p class="impact">
  <strong>{{ m.plant_wc }}</strong> lost
  <strong>{{ "%.0f" | format(m.total_sheet_impact) }} sheets</strong> of OEE Impact this week
  {%- if m.outcome_1 %},
  driven primarily by <strong>{{ m.outcome_1 }}</strong>
  ({{ "%.0f" | format(m.outcome_1_sheets) }} sheets)
  {%- if m.outcome_2 %} and <strong>{{ m.outcome_2 }}</strong>
  ({{ "%.0f" | format(m.outcome_2_sheets) }} sheets){% endif %}{% endif %}.
</p>

{% if m.levers %}
<p>To close those gaps, focus on these top levers:</p>
<ul class="levers">
{% for l in m.levers %}
  <li>
    <strong>{{ l.name }}{% if l.reasons %} — {{ l.reasons }}{% endif %}</strong>
    ({{ l.parent_outcome }},
     {{ "%.0f" | format(l.sheets) }} sheets lost,
     gap {{ "%.1f" | format(l.gap_pct * 100) }}%
     {%- if l.streak > 0 %},
     <span class="streak">{{ l.streak }}/4 weeks above BSP</span>{% endif %})
  </li>
{% endfor %}
</ul>
<p>
  Improving their gap and breaking their streak will move
  <strong>{{ m.outcome_1 }}{% if m.outcome_2 %} and {{ m.outcome_2 }}{% endif %}</strong>.
</p>
{% endif %}

{% if m.findings %}
<div class="findings">
  <h4>Maintenance Findings</h4>
  <p>
    Open: <strong>{{ m.findings.total_open }}</strong> &middot;
    Missing WO: <strong>{{ m.findings.total_missing_wo }}</strong> &middot;
    Overdue: <strong>{{ m.findings.total_overdue }}</strong>
    {%- if m.findings.high_priority_count %}
      &middot; <span style="color:#7b0000;">&#9888; Priority-10: <strong>{{ m.findings.high_priority_count }}</strong></span>
    {%- endif %}
  </p>
  <ul class="findings-sections">
  {% for s in m.findings.by_section %}
    <li{% if s.is_corroborated %} class="corroborated"{% endif %}>
      {{ s.section }} &mdash; {{ s.open_count }} Open
      {%- if s.missing_wo_count %}, {{ s.missing_wo_count }} Missing WO{% endif %}
      {%- if s.overdue_count %}, {{ s.overdue_count }} Overdue{% endif %}
      {%- if s.is_corroborated %} &larr; linked to active lever{% endif %}
    </li>
  {% endfor %}
  </ul>
  {% if m.findings.corroborated_sections %}
  <p class="findings-note">
    Sections marked &larr; are linked to this machine&#39;s active OEE levers.
    Unresolved findings may be contributing to the gaps shown above.
  </p>
  {% endif %}
</div>
{% endif %}

{% endfor %}

<div class="footer">
  Generated automatically by the Folding Carton Actionable Intelligence Platform.
  Do not reply to this email.
</div>
</body>
</html>
